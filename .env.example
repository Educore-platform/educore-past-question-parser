# ─────────────────────────────────────────────────────────────────────────────
# EduCore PDF Parser — Environment Variables
# Copy this file to .env and fill in the values for your environment.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────


# ── MongoDB ───────────────────────────────────────────────────────────────────
# Full MongoDB connection URI.
# For Atlas:    mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
# For local/Docker: mongodb://localhost:27017
MONGO_URL=mongodb://localhost:27017

# Name of the MongoDB database to use.
DB_NAME=educore


# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis connection URL used for caching.
# For local/Docker: redis://localhost:6379
# With auth:        redis://:<password>@<host>:6379
REDIS_URL=redis://localhost:6379


# ── Server ────────────────────────────────────────────────────────────────────
# Port the uvicorn server listens on inside the container (default: 8000).
PORT=8000

# Number of uvicorn worker processes.
# Rule of thumb for CPU-bound work: 2 × <CPU cores> + 1.
# Set to 1 for single-core or during initial testing.
WEB_CONCURRENCY=1

# Uvicorn log level: debug | info | warning | error | critical
LOG_LEVEL=info


# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Local dev defaults (http://localhost:3000, http://127.0.0.1:3000) are always
# included when this variable is not set.
ALLOWED_ORIGINS=http://localhost:3000
